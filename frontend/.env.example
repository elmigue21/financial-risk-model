# Copy to .env.local and fill in.

# Your Groq API key (https://console.groq.com/keys) — enables the AI advisor.
GROQ_API_KEY=

# Where the Python model service is running.
MODEL_API_URL=http://localhost:5000

# Secret used to sign session tokens (auth). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required in production; a dev fallback is used if unset (with a warning).
AUTH_SECRET=
